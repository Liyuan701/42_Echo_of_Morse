# Ce fichier est commité dans le repo uniquement pour l'évaluation finale.
# En développement, chaque membre utilise son propre .env local — ne pas modifier ce fichier.

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL="postgresql://transcendence:transcendence@localhost:5432/transcendence"

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 42 School OAuth
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=

# WebSocket — URL du serveur ws-server
# En développement : http://localhost:3001 (connexion directe)
# En production    : https://localhost:8443 (passe par le WAF en HTTPS)
NEXT_PUBLIC_WS_URL=https://localhost:8443
