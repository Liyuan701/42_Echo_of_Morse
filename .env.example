# Environment template for Echo of Morse.
# Copy this file to .env and fill values for your deployment.

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 42 School OAuth
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=

# Browser Socket.IO endpoint.
# For the local Docker stack this is usually https://localhost:8443.
NEXT_PUBLIC_WS_URL=

# Shared secret used by web and ws-server for socket tokens and internal status updates.
WS_SHARED_SECRET=
